{
  "headers": [
    {
      "source": "/((?!api/|assets/|sitemap\\.xml|robots\\.txt).*)",
      "missing": [
        { "type": "query", "key": "video" },
        { "type": "query", "key": "info" }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/((?!\\.well-known/assetlinks\\.json).*)",
      "has": [{ "type": "host", "value": "creaite.net" }],
      "destination": "https://www.creaite.net/$1",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "creaite.co.kr" }],
      "destination": "https://www.creaite.net/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.creaite.co.kr" }],
      "destination": "https://www.creaite.net/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "creaite.kr" }],
      "destination": "https://www.creaite.net/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.creaite.kr" }],
      "destination": "https://www.creaite.net/:path*",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ai-v-market.vercel.app" }],
      "destination": "https://www.creaite.net/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "query", "key": "video" }],
      "destination": "/api/og"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "query", "key": "info" }],
      "destination": "/api/info"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
